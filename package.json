{
  "name": "algorithm-practice-extension",
  "version": "1.0.3",
  "description": "chrome extension to practice algorithms",
  "scripts": {
    "start": "echo '🚀 Starting the app...' && npm run build && node dist/index.js",
    "build": "echo '🔨 Building the app...' && webpack --mode production",
    "test": "echo '🧪 Running tests...' && jest --config jest.config.cjs --coverage",
    "format": "echo '🖋️ Formatting code...' && prettier --write .",
    "lint": "echo '🧹 Linting code...' && eslint './**/*.{js,ts}' --ignore-path eslintignore",
    "precommit": "echo '🔒 Precommit: Linting and testing code...' && npm run lint && npm test",
    "pretest": "echo '🔎 Pretest: Linting code...' && npm run lint",
    "watch": "echo '👀 Watching files...' && jest --watch",
    "debug": "echo '🐞 Starting the app in debug mode...' && NODE_ENV=development nodemon --inspect src/index.js",
    "clean": "echo '🧽 Cleaning up...' && rm -rf ./node_modules ./dist && rm package-lock.json",
    "prepare": "husky install # 🐶 Setting up Husky",
    "remove-dsstore": "echo '🗑️ Removing .DS_Store files...' && find . -name '.DS_Store' -delete",
    "create-zip": "echo '📦 Creating ZIP file...' && cd .. && zip -r algorithm-practice-extension.zip algorithm-practice-extension/*",
    "package-extension": "echo '📦 Packaging extension...' && npm run remove-dsstore && npm run create-zip"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Jagoda11/algorithm-practice-extension"
  },
  "keywords": [],
  "author": "Jagoda11",
  "license": "Proprietary",
  "bugs": {
    "url": "https://github.com/Jagoda11/algorithm-practice-extension/issues"
  },
  "homepage": "https://github.com/Jagoda11/algorithm-practice-extension#readme",
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.4",
    "@babel/preset-react": "^7.24.7",
    "@babel/preset-typescript": "^7.24.7",
    "@types/jest": "^29.5.13",
    "@types/node": "^22.7.2",
    "@types/react": "^18.3.9",
    "@types/react-dom": "^18.3.0",
    "@types/react-redux": "^7.1.34",
    "@types/react-router-dom": "^5.3.3",
    "@typescript-eslint/eslint-plugin": "^8.7.0",
    "@typescript-eslint/parser": "^8.7.0",
    "babel-loader": "^9.2.1",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.30.0",
    "eslint-plugin-jest": "^28.8.3",
    "eslint-plugin-prettier": "^5.2.1",
    "eslint-plugin-react": "^7.36.1",
    "eslint-plugin-react-hooks": "^4.6.2",
    "husky": "^9.1.6",
    "jest": "^29.7.0",
    "nodemon": "^3.1.7",
    "prettier": "^3.3.3",
    "readline-sync": "^1.4.10",
    "typescript": "^5.6.2",
    "webpack": "^5.95.0",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {
    "autoprefixer": "^10.4.20",
    "axios": "^1.7.7",
    "express": "^4.21.0",
    "postcss": "^8.4.47",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-redux": "^9.1.2",
    "react-router-dom": "^6.26.2",
    "redux": "^5.0.1",
    "tailwindcss": "^3.4.13"
  }
}
